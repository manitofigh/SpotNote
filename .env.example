# Copy this file to .env and fill in your values.

# Your Apple Developer Team ID (10-character code).
SPOTNOTE_TEAM_ID=

# Full signing identity string from `security find-identity -v -p codesigning`.
# If left empty, release.sh auto-detects from SPOTNOTE_TEAM_ID.
SPOTNOTE_SIGNING_IDENTITY=

# Apple ID used for notarization submissions.
SPOTNOTE_NOTARY_APPLE_ID=

# Keychain profile name for notarytool (created by setup_notary_profile.sh).
SPOTNOTE_NOTARY_PROFILE=SpotNote-Profile

# App-specific password: only needed when running setup_notary_profile.sh.
# After that, the password lives in Keychain and this can be removed.
# SPOTNOTE_NOTARY_PASSWORD=
